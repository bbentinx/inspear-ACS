# === Geral ===
APP_NAME=Inspear ACS
APP_ENV=production
SECRET_KEY=change-me-in-production
API_PORT=8000
WEB_PORT=3000

# === PostgreSQL ===
POSTGRES_USER=inspear
POSTGRES_PASSWORD=changeme
POSTGRES_DB=inspear

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Autenticação JWT ===
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRE_MINUTES=480
AUTH_ENABLED=true
ADMIN_EMAIL=admin@inspear.local
ADMIN_PASSWORD=admin123

# === API Key (GenieACS provision + ingestão TR-069) ===
INSPEAR_API_KEY=inspear-dev-key

# === GenieACS ===
# NBI interno Docker (não altere no container api)
GENIEACS_NBI_URL=http://genieacs:7557
# IP do servidor — ONTs apontam CWMP aqui
GENIEACS_CWMP_URL=http://SEU_IP_SERVIDOR:7547
GENIEACS_ACS_USER=inspear
GENIEACS_ACS_PASSWORD=inspear123
GENIEACS_CR_USER=inspear-cr
GENIEACS_CR_PASSWORD=inspear123
GENIEACS_SYNC_ENABLED=true
GENIEACS_SYNC_INTERVAL_SECONDS=300
ALLOW_SIMULATED_ACTIONS=false
OFFLINE_THRESHOLD_MINUTES=15
AUTO_CAPTURE_CONFIG_PROFILE=true

# URL que a ONT alcança para vendor config / speedtest
PUBLIC_API_BASE_URL=http://SEU_IP_SERVIDOR:8000

# === Telegram Alertas ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERTS_ENABLED=false

# === Thresholds diagnóstico ===
OPTICAL_RX_WARN_DBM=-25
OPTICAL_RX_CRIT_DBM=-27
REBOOT_WARN_24H=3
REBOOT_CRIT_24H=6
WIFI_CLIENTS_WARN=15
WIFI_CLIENTS_CRIT=25
CPU_WARN_PCT=80
MEMORY_WARN_PCT=85

# === Teste velocidade TR-069 ===
SPEED_TEST_SERVER_NAME=core Lab Fer
SPEED_TEST_SERVER_CITY=Fernandópolis
SPEED_TEST_SERVER_HOST=SEU_IP_SERVIDOR:8000
SPEED_TEST_DOWNLOAD_URL=http://SEU_IP_SERVIDOR:8000/examples/speedtest/100mb.bin
SPEED_TEST_UPLOAD_URL=http://speedtest.tele2.net/upload.php